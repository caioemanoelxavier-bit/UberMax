/* =========================================================
   UberMax IA — style.css
   Versão completa com estilos para todas as abas
   ========================================================= */

:root {
    --bg-dark: #0f172a;
    --bg-page: #f8fafc;
    --card: #ffffff;
    --text: #111827;
    --muted: #6b7280;
    --border: #e5e7eb;
    --blue: #2563eb;
    --blue-dark: #1d4ed8;
    --blue-light: #eff6ff;
    --green: #22c55e;
    --green-dark: #15803d;
    --green-light: #dcfce7;
    --yellow: #f59e0b;
    --yellow-light: #fef3c7;
    --red: #ef4444;
    --red-light: #fee2e2;
    --shadow: 0 18px 50px rgba(15, 23, 42, 0.12);
    --shadow-sm: 0 4px 16px rgba(15, 23, 42, 0.08);
    --radius: 22px;
    --radius-sm: 14px;
}

/* =========================================================
   RESET E BASE
   ========================================================= */

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: Arial, Helvetica, sans-serif;
    background: var(--bg-page);
    color: var(--text);
    min-height: 100vh;
}

button, input, select, textarea {
    font: inherit;
}

.hidden {
    display: none !important;
}

/* =========================================================
   HERO / TELA INICIAL
   ========================================================= */

.hero {
    min-height: 100vh;
    background:
        radial-gradient(circle at top left, rgba(37, 99, 235, 0.35), transparent 30%),
        radial-gradient(circle at bottom right, rgba(34, 197, 94, 0.25), transparent 26%),
        var(--bg-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 34px 16px;
}

.hero-content {
    width: 100%;
    max-width: 1120px;
    color: white;
    text-align: center;
}

.brand-row {
    display: flex;
    align-items: center;
    gap: 14px;
}

.hero-brand {
    justify-content: center;
    margin-bottom: 22px;
    font-size: 22px;
    font-weight: 800;
}

.logo-mark {
    width: 54px;
    height: 54px;
    border-radius: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--blue), var(--green));
    box-shadow: 0 15px 35px rgba(37, 99, 235, 0.32);
    font-size: 28px;
    flex: 0 0 auto;
}

.hero h1 {
    font-size: clamp(38px, 7vw, 78px);
    line-height: 0.98;
    letter-spacing: -2px;
    margin-bottom: 18px;
}

.hero-subtitle {
    max-width: 760px;
    margin: 0 auto 28px;
    color: #d1d5db;
    font-size: clamp(18px, 2.5vw, 24px);
    line-height: 1.5;
}

.hero-actions {
    display: flex;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
}

.benefits-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
    margin-top: 46px;
}

.benefit-card {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 24px;
    padding: 24px;
    text-align: left;
    backdrop-filter: blur(12px);
}

.benefit-card span {
    font-size: 32px;
}

.benefit-card h3 {
    margin: 12px 0 8px;
    font-size: 19px;
}

.benefit-card p {
    color: #d1d5db;
    line-height: 1.5;
}

/* =========================================================
   BOTÕES
   ========================================================= */

.btn {
    min-height: 48px;
    border: none;
    border-radius: var(--radius-sm);
    padding: 13px 22px;
    font-weight: 800;
    cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
}

.btn:hover {
    transform: translateY(-1px);
}

.btn-primary {
    color: white;
    background: linear-gradient(135deg, var(--blue), var(--green));
    box-shadow: 0 14px 30px rgba(37, 99, 235, 0.26);
}

.btn-primary:hover {
    box-shadow: 0 18px 36px rgba(37, 99, 235, 0.34);
}

.btn-outline {
    background: white;
    color: var(--blue);
    border: 1px solid var(--border);
}

.btn-ghost {
    background: rgba(255, 255, 255, 0.09);
    border: 1px solid rgba(255, 255, 255, 0.18);
    color: white;
}

.link-btn {
    background: none;
    border: none;
    color: var(--blue);
    font-weight: 800;
    cursor: pointer;
    text-decoration: underline;
    padding: 0;
    font-size: inherit;
}

.link-btn:hover {
    color: var(--blue-dark);
}

.full {
    grid-column: 1 / -1;
    width: 100%;
}

/* =========================================================
   APP LAYOUT
   ========================================================= */

.app {
    max-width: 1180px;
    margin: 0 auto;
    padding: 28px 16px 70px;
}

.topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    background: linear-gradient(135deg, #111827, #1f2937);
    color: white;
    border-radius: 26px;
    padding: 28px;
    margin-bottom: 22px;
    box-shadow: var(--shadow);
}

.topbar h1 {
    font-size: 32px;
    letter-spacing: -0.5px;
}

.topbar p {
    color: #d1d5db;
    margin-top: 3px;
}

/* =========================================================
   CARDS
   ========================================================= */

.card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 24px;
    margin-bottom: 22px;
}

.usuario-card {
    border-left: 5px solid var(--blue);
}

.motorista-logado {
    border-left: 5px solid var(--green);
}

.motorista-logado h2 {
    margin: 4px 0;
}

.motorista-logado p,
.section-title p,
.section-header p {
    color: var(--muted);
    line-height: 1.5;
}

.section-title,
.section-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 20px;
}

.section-title h2,
.section-header h2 {
    font-size: 25px;
    margin: 4px 0 5px;
    letter-spacing: -0.4px;
}

.eyebrow {
    display: inline-flex;
    color: var(--blue);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 900;
}

/* =========================================================
   FORMULÁRIOS
   ========================================================= */

.form-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 18px;
}

.form-group {
    display: flex;
    flex-direction: column;
    gap: 7px;
}

label {
    font-weight: 800;
    color: #374151;
}

input,
select,
textarea {
    width: 100%;
    min-height: 48px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 12px 14px;
    background: white;
    color: var(--text);
    outline: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
}

textarea {
    min-height: 95px;
    resize: vertical;
}

input:focus,
select:focus,
textarea:focus {
    border-color: var(--blue);
    box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.12);
}

/* Separador de seções dentro do formulário */
.form-section-label {
    font-size: 13px;
    font-weight: 900;
    color: var(--blue);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 10px 0 2px;
    border-bottom: 2px solid var(--blue-light);
    margin-bottom: 4px;
}

/* =========================================================
   MENSAGENS / ALERTAS
   ========================================================= */

.message {
    margin-top: 16px;
}

.alert {
    border-radius: var(--radius-sm);
    padding: 14px 16px;
    font-weight: 700;
    line-height: 1.45;
}

.alert.success {
    background: var(--green-light);
    color: #166534;
}

.alert.error {
    background: var(--red-light);
    color: #991b1b;
}

.alert.warning {
    background: var(--yellow-light);
    color: #92400e;
}

.alert.info {
    background: var(--blue-light);
    color: #1e40af;
}

/* =========================================================
   NAVEGAÇÃO POR ABAS
   ========================================================= */

.tabs {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 8px;
    background: white;
    border: 1px solid var(--border);
    border-radius: 20px;
    box-shadow: var(--shadow);
    padding: 8px;
    margin-bottom: 22px;
}

.tab-button {
    min-height: 48px;
    border: none;
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--muted);
    font-weight: 900;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
    font-size: 13px;
}

.tab-button:hover {
    background: var(--bg-page);
    color: var(--text);
}

.tab-button.active {
    background: var(--blue);
    color: white;
}

.tab-content {
    display: none;
}

.tab-content.active {
    display: block;
}

/* =========================================================
   RESULTADO / CARDS DE MÉTRICAS
   ========================================================= */

.resultado {
    margin-top: 22px;
    background: #f8fafc;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 22px;
}

.resultado-head {
    margin-bottom: 16px;
}

.resultado-head h3 {
    font-size: 22px;
    margin-top: 4px;
}

.resultado-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
}

.resultado-grid-carro {
    grid-template-columns: repeat(3, 1fr);
}

.resultado-grid div,
.stat-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: 18px;
    padding: 18px;
}

.resultado-grid span,
.stat-card span {
    display: block;
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 7px;
}

.resultado-grid strong,
.stat-card strong {
    font-size: 21px;
    letter-spacing: -0.2px;
}

/* =========================================================
   BOX DE ANÁLISE IA
   ========================================================= */

.ia-box {
    margin-top: 18px;
    background: var(--blue-light);
    border-left: 5px solid var(--blue);
    border-radius: 18px;
    padding: 18px;
    color: #1e3a8a;
    line-height: 1.6;
    font-weight: 600;
}

.ia-box h4 {
    margin-bottom: 6px;
    color: #1d4ed8;
}

/* =========================================================
   HISTÓRICO DE JORNADAS
   ========================================================= */

.historico-lista,
.ranking-lista {
    display: grid;
    gap: 14px;
}

.historico-item {
    display: grid;
    grid-template-columns: 1.3fr repeat(4, 1fr);
    gap: 12px;
    align-items: center;
    background: #ffffff;
    border: 1px solid var(--border);
    border-radius: 18px;
    padding: 18px;
    transition: box-shadow 0.2s ease;
}

.historico-item:hover {
    box-shadow: var(--shadow-sm);
}

.historico-item h3 {
    font-size: 17px;
}

.historico-item small {
    color: var(--muted);
}

.historico-item span {
    display: block;
    color: var(--muted);
    font-size: 13px;
    margin-bottom: 4px;
}

.historico-item strong {
    font-size: 16px;
}

.empty {
    background: #f3f4f6;
    color: var(--muted);
    border-radius: 16px;
    padding: 18px;
    text-align: center;
}

/* =========================================================
   DASHBOARD / STATS
   ========================================================= */

.stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
}

.stat-card {
    background: #f8fafc;
}

.stat-card.lucro {
    background: var(--green-light);
    border-color: #bbf7d0;
}

.stat-card.lucro strong {
    color: #166534;
}

/* =========================================================
   RANKING DE REGIÕES
   ========================================================= */

.ranking-item {
    display: flex;
    align-items: center;
    gap: 14px;
    background: #f8fafc;
    border: 1px solid var(--border);
    border-radius: 18px;
    padding: 16px;
    transition: box-shadow 0.2s ease;
}

.ranking-item:hover {
    box-shadow: var(--shadow-sm);
}

.ranking-posicao {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--blue);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 900;
    flex: 0 0 auto;
}

.ranking-info {
    flex: 1;
}

.ranking-info p {
    color: var(--muted);
    font-size: 14px;
    margin-top: 4px;
}

.ranking-valor {
    color: var(--green-dark);
    font-weight: 900;
    font-size: 18px;
}

/* =========================================================
   ABA MEU CARRO — NOVOS ESTILOS
   ========================================================= */

/* Banner informativo */
.info-banner {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    background: var(--blue-light);
    border: 1px solid #bfdbfe;
    border-radius: 18px;
    padding: 16px 18px;
    margin-bottom: 22px;
}

.info-banner-icon {
    font-size: 24px;
    flex: 0 0 auto;
    margin-top: 2px;
}

.info-banner strong {
    display: block;
    color: #1e40af;
    margin-bottom: 4px;
}

.info-banner p {
    color: #1e3a8a;
    font-size: 14px;
    line-height: 1.5;
}

/* Cards de custo por km */
.custo-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: 18px;
    padding: 18px;
}

.custo-card span {
    display: block;
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 7px;
}

.custo-card strong {
    font-size: 22px;
    letter-spacing: -0.2px;
    font-weight: 900;
}

.custo-combustivel {
    border-top: 4px solid #f97316;
}

.custo-combustivel strong {
    color: #c2410c;
}

.custo-fixo {
    border-top: 4px solid var(--blue);
}

.custo-fixo strong {
    color: var(--blue-dark);
}

.custo-total {
    border-top: 4px solid var(--green);
    background: var(--green-light);
    border-color: #bbf7d0;
}

.custo-total strong {
    color: var(--green-dark);
}

/* Breakdown de custos mensais */
.custo-breakdown {
    margin-top: 20px;
    background: white;
    border: 1px solid var(--border);
    border-radius: 18px;
    padding: 18px;
}

.custo-breakdown h4 {
    font-size: 16px;
    margin-bottom: 14px;
    color: var(--text);
}

.breakdown-lista {
    display: grid;
    gap: 10px;
}

.breakdown-item {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 6px;
    align-items: center;
}

.breakdown-label {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 14px;
    font-weight: 700;
    grid-column: 1 / -1;
}

.breakdown-label span:last-child {
    color: var(--muted);
    font-weight: 600;
}

.breakdown-bar-track {
    height: 8px;
    background: #f3f4f6;
    border-radius: 999px;
    overflow: hidden;
    grid-column: 1;
}

.breakdown-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--blue), var(--green));
    border-radius: 999px;
    transition: width 0.6s ease;
}

.breakdown-pct {
    font-size: 12px;
    color: var(--muted);
    font-weight: 700;
    text-align: right;
    min-width: 36px;
}

.breakdown-total {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 14px;
    padding-top: 14px;
    border-top: 2px solid var(--border);
    font-weight: 800;
}

.breakdown-total strong {
    font-size: 20px;
    color: var(--text);
}

/* Nível de custo com barra de progresso */
.custo-nivel {
    margin-top: 18px;
    background: white;
    border: 1px solid var(--border);
    border-radius: 18px;
    padding: 18px;
}

.custo-nivel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
    font-weight: 700;
    font-size: 14px;
    color: var(--muted);
}

.custo-nivel-badge {
    display: inline-flex;
    align-items: center;
    padding: 4px 12px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 900;
    color: white;
}

.badge-green { background: var(--green); }
.badge-yellow { background: var(--yellow); color: #78350f; }
.badge-red { background: var(--red); }

.custo-nivel-escala {
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    color: var(--muted);
    margin-top: 6px;
}

/* =========================================================
   BARRAS DE PROGRESSO (genéricas)
   ========================================================= */

.progress-bar-track {
    height: 12px;
    background: #f3f4f6;
    border-radius: 999px;
    overflow: hidden;
}

.progress-bar-fill {
    height: 100%;
    border-radius: 999px;
    transition: width 0.7s cubic-bezier(0.4, 0, 0.2, 1);
}

.fill-green {
    background: linear-gradient(90deg, #4ade80, var(--green));
}

.fill-yellow {
    background: linear-gradient(90deg, #fbbf24, var(--yellow));
}

.fill-red {
    background: linear-gradient(90deg, #f87171, var(--red));
}

/* =========================================================
   ABA AVALIAR CORRIDA — NOVOS ESTILOS
   ========================================================= */

/* Aviso de custo do carro */
.aviso-custo,
.info-custo {
    display: flex;
    align-items: center;
    gap: 12px;
    border-radius: 14px;
    padding: 14px 16px;
    margin-bottom: 18px;
    font-weight: 700;
    font-size: 14px;
}

.aviso-custo {
    background: var(--yellow-light);
    border: 1px solid #fde68a;
    color: #92400e;
}

.aviso-custo span,
.info-custo span {
    font-size: 20px;
    flex: 0 0 auto;
}

.info-custo {
    background: var(--green-light);
    border: 1px solid #bbf7d0;
    color: #166534;
}

/* Resultado da corrida */
.corrida-resultado {
    border-width: 2px;
}

/* Badge de recomendação */
.corrida-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    border-radius: 999px;
    padding: 10px 22px;
    color: white;
    font-weight: 900;
    font-size: 18px;
    margin-bottom: 18px;
    letter-spacing: 0.02em;
}

.corrida-badge.aceitar {
    background: linear-gradient(135deg, #16a34a, var(--green));
    box-shadow: 0 8px 20px rgba(34, 197, 94, 0.35);
}

.corrida-badge.pensar {
    background: linear-gradient(135deg, #d97706, var(--yellow));
    box-shadow: 0 8px 20px rgba(245, 158, 11, 0.35);
    color: #1c1917;
}

.corrida-badge.evitar {
    background: linear-gradient(135deg, #dc2626, var(--red));
    box-shadow: 0 8px 20px rgba(239, 68, 68, 0.35);
}

/* Barra de nota da corrida */
.nota-container {
    margin-bottom: 18px;
}

.nota-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
    font-weight: 700;
    font-size: 14px;
    color: var(--muted);
}

.nota-valor {
    font-size: 20px;
    font-weight: 900;
    color: var(--text);
}

.nota-track {
    height: 16px;
    margin-bottom: 6px;
}

.nota-fill.aceitar {
    background: linear-gradient(90deg, #4ade80, var(--green));
}

.nota-fill.pensar {
    background: linear-gradient(90deg, #fbbf24, var(--yellow));
}

.nota-fill.evitar {
    background: linear-gradient(90deg, #f87171, var(--red));
}

.nota-escala {
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    font-weight: 700;
}

.nota-evitar { color: var(--red); }
.nota-pensar { color: var(--yellow); }
.nota-aceitar { color: var(--green-dark); }

/* Detalhes extras da corrida */
.corrida-detalhes {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    margin-top: 14px;
    padding: 14px;
    background: #f8fafc;
    border-radius: 14px;
    border: 1px solid var(--border);
}

.corrida-detalhes div {
    display: flex;
    flex-direction: column;
    gap: 4px;
}

.corrida-detalhes span {
    font-size: 12px;
    color: var(--muted);
    font-weight: 700;
}

.corrida-detalhes strong {
    font-size: 15px;
    font-weight: 800;
}

/* =========================================================
   HISTÓRICO DE CORRIDAS AVALIADAS
   ========================================================= */

.corrida-item {
    display: grid;
    grid-template-columns: 1.2fr repeat(4, 1fr);
    gap: 12px;
    align-items: center;
    background: #ffffff;
    border: 1px solid var(--border);
    border-radius: 18px;
    padding: 18px;
    transition: box-shadow 0.2s ease;
}

.corrida-item:hover {
    box-shadow: var(--shadow-sm);
}

.corrida-item h3 {
    font-size: 16px;
    margin: 4px 0;
}

.corrida-item small {
    color: var(--muted);
    font-size: 13px;
}

.corrida-item span:not(.status) {
    display: block;
    color: var(--muted);
    font-size: 13px;
    margin-bottom: 4px;
}

.corrida-item strong {
    font-size: 16px;
}

/* Status badges nas corridas */
.status {
    display: inline-flex;
    width: fit-content;
    border-radius: 999px;
    padding: 5px 10px;
    color: white;
    font-weight: 900;
    font-size: 12px;
    margin-bottom: 5px;
}

.status.aceitar { background: var(--green); }
.status.pensar { background: var(--yellow); color: #1c1917; }
.status.evitar { background: var(--red); }

/* Mini barra de progresso nas corridas do histórico */
.mini-progress {
    height: 5px;
    background: #f3f4f6;
    border-radius: 999px;
    overflow: hidden;
    margin-top: 5px;
}

.mini-progress-fill {
    height: 100%;
    border-radius: 999px;
    transition: width 0.5s ease;
}

.mini-progress-fill.aceitar { background: var(--green); }
.mini-progress-fill.pensar { background: var(--yellow); }
.mini-progress-fill.evitar { background: var(--red); }

/* Estatísticas de corridas (aceitar/pensar/evitar) */
.corridas-stats {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
}

.mini-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 8px 14px;
    border-radius: 12px;
    min-width: 70px;
    text-align: center;
}

.mini-stat span {
    font-size: 12px;
    font-weight: 700;
    margin-bottom: 2px;
}

.mini-stat strong {
    font-size: 20px;
    font-weight: 900;
}

.aceitar-stat {
    background: var(--green-light);
    color: #166534;
}

.pensar-stat {
    background: var(--yellow-light);
    color: #92400e;
}

.evitar-stat {
    background: var(--red-light);
    color: #991b1b;
}

/* =========================================================
   RESPONSIVIDADE
   ========================================================= */

@media (max-width: 1100px) {
    .resultado-grid {
        grid-template-columns: repeat(2, 1fr);
    }

    .corrida-detalhes {
        grid-template-columns: repeat(2, 1fr);
    }
}

@media (max-width: 980px) {
    .benefits-grid,
    .stats-grid {
        grid-template-columns: repeat(2, 1fr);
    }

    .resultado-grid,
    .resultado-grid-carro {
        grid-template-columns: repeat(2, 1fr);
    }

    .tabs {
        grid-template-columns: repeat(3, 1fr);
    }

    .historico-item,
    .corrida-item {
        grid-template-columns: 1fr 1fr;
    }

    .corrida-detalhes {
        grid-template-columns: repeat(2, 1fr);
    }
}

@media (max-width: 768px) {
    .hero {
        padding: 28px 14px;
    }

    .hero h1 {
        letter-spacing: -1px;
    }

    .hero-actions,
    .topbar,
    .section-header,
    .ranking-item {
        flex-direction: column;
        align-items: stretch;
    }

    .topbar {
        padding: 22px;
    }

    .benefits-grid,
    .form-grid,
    .stats-grid,
    .resultado-grid,
    .resultado-grid-carro,
    .historico-item,
    .corrida-item,
    .corrida-detalhes {
        grid-template-columns: 1fr;
    }

    .tabs {
        grid-template-columns: 1fr 1fr;
    }

    .card {
        padding: 18px;
    }

    .btn,
    input,
    select,
    textarea {
        min-height: 48px;
        font-size: 16px;
    }

    .corridas-stats {
        justify-content: center;
    }

    .tab-button {
        font-size: 12px;
        padding: 8px 4px;
    }
}

@media (max-width: 480px) {
    .tabs {
        grid-template-columns: 1fr;
    }

    .resultado-grid {
        grid-template-columns: 1fr;
    }

    .nota-escala {
        font-size: 10px;
    }
}
